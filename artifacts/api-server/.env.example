# API Server Configuration

# Environment
NODE_ENV=production

# Server
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/jamiati

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# CORS Origins (comma-separated)
# Examples:
# - Development: http://localhost:3000,http://localhost:5173,http://localhost:5174
# - Production: https://student.jamiati.com,https://admin.jamiati.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Mobile API Base URL (used by Expo clients)
# Development: http://localhost:3000
# Production: https://api.jamiati.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Optional: Storage provider configuration (for future use)
# STORAGE_PROVIDER=s3
# S3_BUCKET=jamiati-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-key
# S3_SECRET_ACCESS_KEY=your-secret
